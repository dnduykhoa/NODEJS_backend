PORT=3000
NODE_ENV=development
APP_BASE_URL=http://localhost:3000
MONGODB_URI=mongodb://localhost:27017/nodejs-backend

JWT_SECRET=replace-with-long-random-secret
JWT_EXPIRES_IN=7d
SESSION_SECRET=replace-with-long-random-session-secret

DEFAULT_ROLE_ID=replace-with-default-role-objectid

GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
GOOGLE_CALLBACK_URL=/auth/google/callback

MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=mailer@example.com
MAIL_PASS=replace-with-mail-password
MAIL_FROM="NODEJS Backend <no-reply@example.com>"

RESET_PASSWORD_TOKEN_TTL_MS=3600000